      if ($e.attr('id') === $extQuery.attr('id')) {
        return;
      }

      var $doc = getResult($e);

      if (!$doc || $doc.length === 0) {
        return;
      }

      var dataUrl = $e.data('url');

      if ($e.data('normal') && dataUrl) {
        addSet(urls, dataUrl);
        return;
      }

      var docUrls = getDocUrls($doc, DOC_URL_LIMIT);

      if (docUrls && docUrls.length >= 1) {
        urls = urls.concat(docUrls);
        return;
      }

      if (dataUrl) {
        addSet(urls, dataUrl);
      }
    });
    return urls.slice(0, ALL_URL_LIMIT);
